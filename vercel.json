{
    "version": 2,
    "builds": [
        {
            "src": "public/**/*",
            "use": "@vercel/static"
        },
        {
            "src": "server.js",
            "use": "@vercel/node"
        }
    ],
    "routes": [
        {
            "src": "/create-checkout-session",
            "dest": "/server.js"
        },
        {
            "src": "/config",
            "dest": "/server.js"
        },
        {
            "src": "/webhook",
            "dest": "/server.js"
        },
        {
            "src": "/",
            "dest": "/public/index.html"
        },
        {
            "src": "/(.*)",
            "dest": "/public/$1"
        }
    ]
}